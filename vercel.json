{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.js",
      "use": "@vercel/static"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/architecture", "destination": "/architecture.html" },
    { "source": "/ontology", "destination": "/ontology.html" },
    { "source": "/data-intelligence", "destination": "/data-intelligence.html" },
    { "source": "/optimization", "destination": "/optimization.html" },
    { "source": "/causal-monitoring", "destination": "/causal-monitoring.html" },
    { "source": "/security-roadmap", "destination": "/security-roadmap.html" }
  ]
}
